<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Smoke_Test_Suite">

	<groups>
		<run>
			<include name="SmokeTest"></include>
		</run>
	</groups>

	<listeners>
		<listener
			class-name="com.comcast.crm.generic.listenerutility.ListenerImpClass" />
	</listeners>


	<test name="Test">
		<classes>
			<class
				name="com.comcast.crm.contacttest.ContactTest" />
			<class
				name="com.comcast.crm.orgtest.organizationE2ETest" />
		</classes>
	</test>
</suite> 
